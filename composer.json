{
    "name": "ami-praha/ami-ai-skills",
    "description": "Set of shared AI skills for every AI supported project.",
    "keywords": [
        "AMI-Praha-a-s",
        "ami-ai-skills"
    ],
    "license": "MIT",
    "authors": [
        {
            "name": "AMI Praha a.s.",
            "email": "info@ami.cz",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2"
    },
    "require-dev": {
        "laravel/pint": "^1.0",
        "pestphp/pest": "^4.0"
    },
    "autoload": {
        "psr-4": {
            "AmiPraha\\AmiAiSkills\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "AmiPraha\\AmiAiSkills\\Tests\\": "tests"
        }
    },
    "scripts": {
        "test": "vendor/bin/pest",
        "test-coverage": "vendor/bin/pest --coverage",
        "format": "vendor/bin/pint"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
